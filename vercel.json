{
  "functions": {
    "api/gemini.js": { "memory": 256, "maxDuration": 15 },
    "api/maps-config.js": { "memory": 128, "maxDuration": 5 }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" }
      ]
    }
  ]
}
