# Copy this file to .env.local for local development.
# Set these as Environment Variables in your Vercel project settings for production.
# Never commit real keys to version control.

# Gemini API key — get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Google Maps JS API key — create at https://console.cloud.google.com
# Enable: Maps JavaScript API, Places API, Directions API
# Restrict to your production domain: https://voteready-pi.vercel.app
GOOGLE_MAPS_KEY=your_google_maps_api_key_here

# CORS allowed origin for the /api/* serverless functions
ALLOWED_ORIGIN=https://voteready-pi.vercel.app
